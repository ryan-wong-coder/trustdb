# Example environment for local TiKV dev + docker-compose.tikv.yml.
#
# Docker Compose loads a repo-root `.env` file automatically for ${VAR} substitution
# in docker-compose.tikv.yml. Copy the lines you need:
#   cp scripts/tikv-dev.env.example .env
# (`.env` is gitignored.)
#
# tikv-dev.ps1 / tikv-dev.sh native mode also honor these when starting containers.

TRUSTDB_TIKV_PD_IMAGE=pingcap/pd:v7.5.0
TRUSTDB_TIKV_TIKV_IMAGE=pingcap/tikv:v7.5.0
